{
	"info": {
		"name": "Magpie API",
		"description": "Full API collection for Magpie — a platform for sharing AI coding workflows.\n\nSetup:\n1. Sign in via browser at {{baseUrl}}/auth/login/github\n2. Copy the `auth_session` cookie from browser dev tools\n3. Paste it into the collection variable `sessionToken`\n4. Replace `{{owner}}` and `{{slug}}` variables as needed",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:5173",
			"type": "string"
		},
		{
			"key": "sessionToken",
			"value": "",
			"type": "string",
			"description": "Paste your auth_session cookie value here"
		},
		{
			"key": "owner",
			"value": "",
			"type": "string",
			"description": "Your GitHub username (lowercase)"
		},
		{
			"key": "slug",
			"value": "my-claude-setup",
			"type": "string",
			"description": "Setup slug to test with"
		},
		{
			"key": "deviceCode",
			"value": "",
			"type": "string",
			"description": "Populated by Device Flow — Initiate request"
		}
	],
	"item": [
		{
			"name": "Health",
			"item": [
				{
					"name": "Health Check",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/v1/health",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "health"]
						},
						"description": "Verify server is running. No auth needed."
					}
				}
			]
		},
		{
			"name": "Auth",
			"item": [
				{
					"name": "Logout",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Cookie",
								"value": "auth_session={{sessionToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/auth/logout",
							"host": ["{{baseUrl}}"],
							"path": ["auth", "logout"]
						},
						"description": "Invalidates session and deletes cookie. Returns 302 redirect to /.\n\nTip: Disable 'Follow redirects' in Postman settings to see the 302."
					}
				},
				{
					"name": "Device Flow — Initiate",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    const body = pm.response.json();",
									"    if (body.data && body.data.deviceCode) {",
									"        pm.collectionVariables.set('deviceCode', body.data.deviceCode);",
									"        console.log('deviceCode saved:', body.data.deviceCode);",
									"        console.log('Go to: ' + body.data.verificationUri);",
									"        console.log('Enter code: ' + body.data.userCode);",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/v1/auth/device",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "auth", "device"]
						},
						"description": "Starts the GitHub device flow for CLI auth.\n\nReturns a userCode and verificationUri. The deviceCode is auto-saved to collection variables for the poll request."
					}
				},
				{
					"name": "Device Flow — Poll",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"deviceCode\": \"{{deviceCode}}\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/auth/device/poll",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "auth", "device", "poll"]
						},
						"description": "Poll for device flow completion.\n\nExpected responses:\n- 202: { data: { status: 'pending' } } — user hasn't authorized yet\n- 429: { data: { status: 'slow_down' } } — polling too fast\n- 200: { data: { token: '...' } } — success, use as Bearer token"
					}
				}
			]
		},
		{
			"name": "Setups",
			"item": [
				{
					"name": "Create Setup",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Cookie",
								"value": "auth_session={{sessionToken}}"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"name\": \"My Claude Setup\",\n\t\"slug\": \"my-claude-setup\",\n\t\"description\": \"A minimal Claude Code workflow for TypeScript projects\",\n\t\"version\": \"1.0.0\",\n\t\"files\": [\n\t\t{\n\t\t\t\"source\": \"CLAUDE.md\",\n\t\t\t\"target\": \"CLAUDE.md\",\n\t\t\t\"placement\": \"project\",\n\t\t\t\"description\": \"Main Claude instructions\",\n\t\t\t\"content\": \"# Project\\n\\nUse TypeScript strict mode.\"\n\t\t}\n\t]\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/setups",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "setups"]
						},
						"description": "Create a new setup. Requires auth.\n\nTest cases:\n- 201: Created successfully\n- 409: Duplicate slug (send again)\n- 401: Remove cookie to test unauthed"
					}
				},
				{
					"name": "Get Setup",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/v1/setups/{{owner}}/{{slug}}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "setups", "{{owner}}", "{{slug}}"]
						},
						"description": "Get a setup by owner and slug. Public, no auth needed.\n\nTest: Use owner=nobody, slug=fake to get a 404."
					}
				},
				{
					"name": "Update Setup",
					"request": {
						"method": "PATCH",
						"header": [
							{
								"key": "Cookie",
								"value": "auth_session={{sessionToken}}"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"description\": \"Updated description for my setup\",\n\t\"version\": \"1.1.0\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/setups/{{owner}}/{{slug}}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "setups", "{{owner}}", "{{slug}}"]
						},
						"description": "Update a setup you own. Requires auth.\n\nAll fields are optional. Placement values: global, project, relative.\n\nTest: Use a different user's setup to get 403."
					}
				},
				{
					"name": "Delete Setup",
					"request": {
						"method": "DELETE",
						"header": [
							{
								"key": "Cookie",
								"value": "auth_session={{sessionToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/v1/setups/{{owner}}/{{slug}}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "setups", "{{owner}}", "{{slug}}"]
						},
						"description": "Delete a setup you own. Requires auth.\n\nReturns { data: { deleted: true } }.\n\nTest: Use a different user's setup to get 403."
					}
				},
				{
					"name": "Get Setup Files",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/v1/setups/{{owner}}/{{slug}}/files",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "setups", "{{owner}}", "{{slug}}", "files"]
						},
						"description": "Get all files for a setup. Public, no auth needed.\n\nUsed by the CLI's `magpie clone` command."
					}
				}
			]
		},
		{
			"name": "Error Cases",
			"item": [
				{
					"name": "Create Setup — No Auth (expect 401)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"name\": \"Should Fail\",\n\t\"slug\": \"should-fail\",\n\t\"description\": \"This should return 401\",\n\t\"version\": \"1.0.0\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/setups",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "setups"]
						},
						"description": "Attempt to create a setup without auth. Expect 401."
					}
				},
				{
					"name": "Get Setup — Not Found (expect 404)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/v1/setups/nobody/does-not-exist",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "setups", "nobody", "does-not-exist"]
						},
						"description": "Request a non-existent setup. Expect 404."
					}
				},
				{
					"name": "Device Flow Poll — Missing Body (expect 400)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/auth/device/poll",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "auth", "device", "poll"]
						},
						"description": "Poll without a deviceCode. Expect 400 validation error."
					}
				}
			]
		}
	]
}

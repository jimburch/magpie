{
	"name": "magpie",
	"version": "0.1.0",
	"description": "Magpie CLI — clone, publish, and manage AI coding setups",
	"type": "module",
	"main": "dist/index.js",
	"bin": {
		"magpie": "bin/magpie.js"
	},
	"scripts": {
		"build": "tsup src/index.ts --format esm --dts --outDir dist",
		"dev": "tsx src/index.ts",
		"test": "vitest run",
		"test:unit": "vitest run"
	},
	"dependencies": {
		"commander": "^12.1.0",
		"picocolors": "^1.1.1"
	},
	"devDependencies": {
		"tsup": "^8.5.1",
		"tsx": "^4.0.0",
		"typescript": "^5.9.3",
		"vitest": "^2.1.9"
	}
}
